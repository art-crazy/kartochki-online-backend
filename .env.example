# Окружение приложения для локального запуска.
APP_ENV=local

# Адрес, на котором backend слушает HTTP-запросы.
HTTP_HOST=0.0.0.0

# Порт backend API.
HTTP_PORT=8080

# Подключение к локальному PostgreSQL из docker-compose.yml.
POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/kartochki_online?sslmode=disable

# Адрес локального Redis из docker-compose.yml.
REDIS_ADDR=localhost:6379

# Client ID приложения Яндекс ID для входа через Яндекс.
YANDEX_CLIENT_ID=mock_yandex_client_id

# Client Secret приложения Яндекс ID для входа через Яндекс.
YANDEX_CLIENT_SECRET=mock_yandex_client_secret

# ID приложения VK ID для входа через VK.
VK_ID_APP_ID=10000000

# Client Secret приложения VK ID для входа через VK.
VK_ID_CLIENT_SECRET=mock_vk_client_secret

# API-ключ RouterAI для генерации изображений. Если оставить пустым, реальная генерация будет отключена.
ROUTERAI_API_KEY=mock_routerai_api_key

# GitHub Secrets для deploy workflow. Эти значения не обязательны для локального .env,
# но нужны в настройках репозитория GitHub для .github/workflows/deploy.yml.

# IP или домен сервера.
# SERVER_HOST=203.0.113.10

# Пользователь для деплоя на сервере.
# SERVER_USER=deploy_user

# Приватный SSH-ключ пользователя SERVER_USER.
# SERVER_DEPLOY_SSH_KEY=-----BEGIN OPENSSH PRIVATE KEY-----MOCK-----END OPENSSH PRIVATE KEY-----

# Токен Telegram bot для Telegram Login Widget.
# AUTH_TELEGRAM_BOT_TOKEN=0000000000:mock_telegram_bot_token

# SMTP host. Если пустой, письма реально не отправляются.
# SMTP_HOST=smtp.example.com

# SMTP port. Обычно 465 для implicit TLS.
# SMTP_PORT=465

# SMTP пользователь.
# SMTP_USER=mailer@example.com

# SMTP пароль.
# SMTP_PASSWORD=mock_smtp_password

# Email отправителя. Обязателен, если задан SMTP_HOST.
# EMAIL_FROM=no-reply@example.com

# Имя отправителя в письмах.
# EMAIL_FROM_NAME=Example App

# ID магазина ЮКасса. Если пустой, реальные платежи отключены.
# YOOKASSA_SHOP_ID=000000

# Секретный ключ ЮКасса.
# YOOKASSA_SECRET_KEY=mock_yookassa_secret_key

# Секрет webhook ЮКасса.
# YOOKASSA_WEBHOOK_SECRET=mock_yookassa_webhook_secret

# Публичные production-домены не являются секретами и лежат в config/production.env.
