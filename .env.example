APP_NAME=kartochki-online-backend
APP_ENV=local
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_REQUEST_TIMEOUT=30s
HTTP_READ_TIMEOUT=5s
HTTP_WRITE_TIMEOUT=10s
HTTP_IDLE_TIMEOUT=30s
HTTP_SHUTDOWN_TIMEOUT=10s
AUTH_ALLOWED_ORIGINS=http://localhost:3000,https://kartochki-online.ru,https://xn----7sbabjowfpen9ag6h.xn--p1ai

POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/kartochki_online?sslmode=disable
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

ASYNQ_CONCURRENCY=10

STORAGE_ROOT_DIR=./storage
STORAGE_PUBLIC_PATH=/media

AUTH_SESSION_TTL=720h
AUTH_PASSWORD_MIN_LENGTH=8
# Время жизни токена сброса пароля. Токен одноразовый — после использования он помечается.
AUTH_PASSWORD_RESET_TOKEN_TTL=1h
# Максимальное время ожидания отправки письма через SMTP или сторонний провайдер.
AUTH_EMAIL_SEND_TIMEOUT=30s

# OAuth-поля можно оставить пустыми, пока не начнётся настройка провайдера.
VK_ID_APP_ID=
VK_ID_CLIENT_SECRET=

YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# Telegram Login Widget присылает уже подписанные данные пользователя на frontend.
# Backend проверяет подпись по токену бота и открывает локальную сессию.
AUTH_TELEGRAM_BOT_TOKEN=
AUTH_TELEGRAM_AUTH_MAX_AGE=15m

# RouterAI: генерация изображений карточек через AI.
# Модель выбирается пользователем при каждой генерации — список доступен через GET /api/v1/generate/config.
# При пустом ROUTERAI_API_KEY генерация будет падать в статус failed.
ROUTERAI_API_KEY=
ROUTERAI_ENDPOINT=https://routerai.ru/api/v1
ROUTERAI_TIMEOUT=120s
